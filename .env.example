# Kopier denne fil til .env og udfyld værdierne
# I Coolify sættes disse som Environment Variables i projektet

# Neon PostgreSQL connection string
# Find den i Neon dashboard → dit projekt → Connection string
DATABASE_URL=postgresql://brugernavn:adgangskode@host.neon.tech/databasenavn?sslmode=require

# Port (Coolify sætter denne automatisk)
PORT=3000
